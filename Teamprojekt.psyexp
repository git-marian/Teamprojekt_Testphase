        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="direction = np.random.choice([&quot;LR&quot;, &quot;RL&quot;]);&amp;#10;psychoJS.experiment.addData(&quot;direction&quot;, direction);&amp;#10;if ((direction === &quot;LR&quot;)) {&amp;#10;    leftFrame1_Pos = [(- 6), 3];&amp;#10;    middleFrame1_Pos = [(- 2), 3];&amp;#10;    rightFrame1_Pos = [2, 3];&amp;#10;    leftFrame2_Pos = [(- 2), 3];&amp;#10;    middleFrame2_Pos = [2, 3];&amp;#10;    rightFrame2_Pos = [6, 3];&amp;#10;} else {&amp;#10;    if ((direction === &quot;RL&quot;)) {&amp;#10;        leftFrame1_Pos = [(- 2), 3];&amp;#10;        middleFrame1_Pos = [2, 3];&amp;#10;        rightFrame1_Pos = [6, 3];&amp;#10;        leftFrame2_Pos = [(- 6), 3];&amp;#10;        middleFrame2_Pos = [(- 2), 3];&amp;#10;        rightFrame2_Pos = [2, 3];&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="direction = np.random.choice([&quot;LR&quot;, &quot;RL&quot;])&amp;#10;thisExp.addData(&quot;direction&quot;, direction)&amp;#10;&amp;#10;if direction == &quot;LR&quot;:&amp;#10;    leftFrame1_Pos = (-6, 3)&amp;#10;    middleFrame1_Pos = (-2, 3)&amp;#10;    rightFrame1_Pos = (2, 3)&amp;#10;&amp;#10;    leftFrame2_Pos = (-2, 3)&amp;#10;    middleFrame2_Pos = (2, 3)&amp;#10;    rightFrame2_Pos = (6, 3)&amp;#10;&amp;#10;elif direction == &quot;RL&quot;:&amp;#10;    leftFrame1_Pos = (-2, 3)&amp;#10;    middleFrame1_Pos = (2, 3)&amp;#10;    rightFrame1_Pos = (6, 3)&amp;#10;&amp;#10;    leftFrame2_Pos = (-6, 3)&amp;#10;    middleFrame2_Pos = (-2, 3)&amp;#10;    rightFrame2_Pos = (2, 3)" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
