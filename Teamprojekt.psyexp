        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Ich wurde schriftlich über die Inhalte und den Ablauf der 30-minütigen Studie aufgeklärt. &amp;#10;&amp;#10;Mit der in den Teilnehmendeninformationen beschriebenen anonymen Erhebung und Verarbeitung der Experimentaldaten sowie Alter und Geschlecht bin ich einverstanden.  &amp;#10;&amp;#10;Ich bin damit einverstanden, dass die anonymen Daten zu Forschungszwecken weiterverwendet werden können und langfristig in einem wissenschaftlichen Online-Datenarchiv öffentlich zugänglich gemacht werden (z.B. Open Research Plattform Zenodo [https://zenodo.org/]).   &amp;#10;&amp;#10;Ich versichere, dass ich mindestens 18 Jahre alt bin, über eine normale oder korrigierte Sehfähigkeit verfüge, die Informationen gelesen und verstanden habe und genügend Zeit für eine Entscheidung hatte.&amp;#10;&amp;#10;Ich weiß, dass die Teilnahme an der Studie freiwillig ist und ich die Teilnahme jederzeit ohne Angaben von Gründen beenden kann. &amp;#10;&amp;#10;Mit dem Drücken der “J” Taste erkläre mich dazu bereit an der oben genannten Studie teilzunehmen. &amp;#10;&amp;#10;Bei Fragen oder anderen Anliegen kann ich mich an folgende Personen wenden: Dr. Elisabeth Hein, Schleichstrasse 4, 72076 Tübingen, Telefon: 07071 29-75641, elisabeth.hein@uni-tuebingen.de&amp;#10;&amp;#10;" valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
        <Param val="" valType="code" updates="None" name="validator"/>
        <Param val="1.5" valType="num" updates="constant" name="wrapWidth"/>
      </TextComponent>
