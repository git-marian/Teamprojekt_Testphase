        <Param val="participantID = int(expInfo[&quot;participant&quot;])&amp;#10;&amp;#10;if participantID % 2 == 1:&amp;#10;    group = &quot;A&quot;&amp;#10;else:&amp;#10;    group = &quot;B&quot;&amp;#10;&amp;#10;thisExp.addData(&quot;group&quot;, group)&amp;#10;&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
