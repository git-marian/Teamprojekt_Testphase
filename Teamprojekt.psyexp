        <Param val="True" valType="bool" updates="None" name="saveStartStop"/>
        <Param val="" valType="code" updates="constant" name="skipIf"/>
        <Param val="duration (s)" valType="str" updates="None" name="stopType"/>
        <Param val="" valType="code" updates="constant" name="stopVal"/>
        <Param val="False" valType="bool" updates="None" name="useWindowParams"/>
      </RoutineSettingsComponent>
      <CodeComponent name="codeObjectParametersPractice" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="# default Frame 2 Ternus colors&amp;#10;leftFrame2_Color = &quot;black&quot;&amp;#10;middleFrame2_Color = &quot;black&quot;&amp;#10;rightFrame2_Color = &quot;black&quot;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="leftFrame2_Color = &quot;black&quot;;&amp;#10;middleFrame2_Color = &quot;black&quot;;&amp;#10;rightFrame2_Color = &quot;black&quot;;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="colorList = [&quot;#E41A1C&quot;, &quot;#1E88E5&quot;, &quot;#2EBD59&quot;, &quot;#C200FB&quot;];&amp;#10;causalColor = np.random.choice(colorList);&amp;#10;direction = np.random.choice([&quot;LR&quot;, &quot;RL&quot;]);&amp;#10;if ((direction === &quot;LR&quot;)) {&amp;#10;    leftFrame1_Pos = [(- 6), 3];&amp;#10;    middleFrame1_Pos = [(- 2), 3];&amp;#10;    rightFrame1_Pos = [2, 3];&amp;#10;    leftFrame2_Pos = [(- 2), 3];&amp;#10;    middleFrame2_Pos = [2, 3];&amp;#10;    rightFrame2_Pos = [6, 3];&amp;#10;} else {&amp;#10;    if ((direction === &quot;RL&quot;)) {&amp;#10;        leftFrame1_Pos = [(- 2), 3];&amp;#10;        middleFrame1_Pos = [2, 3];&amp;#10;        rightFrame1_Pos = [6, 3];&amp;#10;        leftFrame2_Pos = [(- 6), 3];&amp;#10;        middleFrame2_Pos = [(- 2), 3];&amp;#10;        rightFrame2_Pos = [2, 3];&amp;#10;    }&amp;#10;}&amp;#10;portalOpacity = 0;&amp;#10;barrierOpacity = 0;&amp;#10;barrierPos = [2, 2];&amp;#10;ternusColor = &quot;black&quot;;&amp;#10;leftFrame2_Color = &quot;black&quot;;&amp;#10;middleFrame2_Color = &quot;black&quot;;&amp;#10;rightFrame2_Color = &quot;black&quot;;&amp;#10;if ((conditions_practice === &quot;Portal&quot;)) {&amp;#10;    portalOpacity = 1;&amp;#10;    barrierOpacity = 0;&amp;#10;} else {&amp;#10;    if ((conditions_practice === &quot;Barrier&quot;)) {&amp;#10;        portalOpacity = 0;&amp;#10;        barrierOpacity = 1;&amp;#10;    } else {&amp;#10;        if ((conditions_practice === &quot;Standard&quot;)) {&amp;#10;            portalOpacity = 0;&amp;#10;            barrierOpacity = 0;&amp;#10;            ternusColor = &quot;black&quot;;&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;if (((conditions_practice === &quot;Portal&quot;) || (conditions_practice === &quot;Barrier&quot;))) {&amp;#10;    if ((direction === &quot;LR&quot;)) {&amp;#10;        rightFrame2_Color = causalColor;&amp;#10;        barrierPos = [4, 3];&amp;#10;    } else {&amp;#10;        if ((direction === &quot;RL&quot;)) {&amp;#10;            leftFrame2_Color = causalColor;&amp;#10;            barrierPos = [(- 4), 3];&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;psychoJS.experiment.addData(&quot;causalColor&quot;, causalColor);&amp;#10;psychoJS.experiment.addData(&quot;direction&quot;, direction);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="colorList = [&amp;#10;    &quot;#E41A1C&quot;,  # red&amp;#10;    &quot;#1E88E5&quot;,  # blue&amp;#10;    &quot;#2EBD59&quot;,  # green&amp;#10;    &quot;#C200FB&quot;,  # purple&amp;#10;]&amp;#10;&amp;#10;causalColor = np.random.choice(colorList)&amp;#10;&amp;#10;direction = np.random.choice([&quot;LR&quot;, &quot;RL&quot;])&amp;#10;&amp;#10;if direction == &quot;LR&quot;:&amp;#10;    leftFrame1_Pos = (-6, 3)&amp;#10;    middleFrame1_Pos = (-2, 3)&amp;#10;    rightFrame1_Pos = (2, 3)&amp;#10;&amp;#10;    leftFrame2_Pos = (-2, 3)&amp;#10;    middleFrame2_Pos = (2, 3)&amp;#10;    rightFrame2_Pos = (6, 3)&amp;#10;&amp;#10;elif direction == &quot;RL&quot;:&amp;#10;    leftFrame1_Pos = (-2, 3)&amp;#10;    middleFrame1_Pos = (2, 3)&amp;#10;    rightFrame1_Pos = (6, 3)&amp;#10;&amp;#10;    leftFrame2_Pos = (-6, 3)&amp;#10;    middleFrame2_Pos = (-2, 3)&amp;#10;    rightFrame2_Pos = (2, 3)&amp;#10;&amp;#10;# default: invisible causal objects&amp;#10;portalOpacity = 0&amp;#10;barrierOpacity = 0&amp;#10;barrierPos = (2,2)&amp;#10;&amp;#10;# default Ternus color&amp;#10;ternusColor = &quot;black&quot;&amp;#10;&amp;#10;# reset every trial&amp;#10;leftFrame2_Color = &quot;black&quot;&amp;#10;middleFrame2_Color = &quot;black&quot;&amp;#10;rightFrame2_Color = &quot;black&quot;&amp;#10;&amp;#10;if conditions_practice == &quot;Portal&quot;:&amp;#10;    portalOpacity = 1&amp;#10;    barrierOpacity = 0&amp;#10;&amp;#10;&amp;#10;elif conditions_practice == &quot;Barrier&quot;:&amp;#10;    portalOpacity = 0&amp;#10;    barrierOpacity = 1&amp;#10;&amp;#10;&amp;#10;elif conditions_practice == &quot;Standard&quot;:&amp;#10;    portalOpacity = 0&amp;#10;    barrierOpacity = 0&amp;#10;    ternusColor = &quot;black&quot;&amp;#10;&amp;#10;# color-change only in Portal/Barrier&amp;#10;if conditions_practice == &quot;Portal&quot; or conditions_practice == &quot;Barrier&quot;:&amp;#10;    if direction == &quot;LR&quot;:&amp;#10;        rightFrame2_Color = causalColor&amp;#10;        barrierPos = (4,3)&amp;#10;    elif direction == &quot;RL&quot;:&amp;#10;        leftFrame2_Color = causalColor&amp;#10;        barrierPos = (-4,3)&amp;#10;&amp;#10;thisExp.addData(&quot;causalColor&quot;, causalColor)&amp;#10;thisExp.addData(&quot;direction&quot;, direction)" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="codeObjectParametersPractice" valType="code" updates="None" name="name"/>
      </CodeComponent>
