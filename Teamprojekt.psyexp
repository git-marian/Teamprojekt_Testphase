        <Param val="Bei sehr kurzen Unterbrechungen entsteht häufig der Eindruck einer Elementbewegung.&amp;#10;&amp;#10;&amp;#10;&amp;#10;Dabei scheinen die beiden mittleren Kreise an ihrer Position zu bleiben, während links ein Kreis verschwindet und rechts ein neuer Kreis erscheint.&amp;#10;&amp;#10;&amp;#10;&amp;#10;Drücke die Leertaste, um fortzufahren." valType="str" updates="constant" name="text"/>
