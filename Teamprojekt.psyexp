 'portal'), ('start_index', 1), ('ziel_index', 3), ('durchgang_index', 0), ('farbe', 'lila'), ('loesung', 'right right right right right right ')]), OrderedDict([('typ', 'portal'), ('start_index', 2), ('ziel_index', 0), ('durchgang_index', 0), ('farbe', 'rot'), ('loesung', 'left left left left left left')]), OrderedDict([('typ', 'portal'), ('start_index', 2), ('ziel_index', 0), ('durchgang_index', 0), ('farbe', 'lila'), ('loesung', 'right right')])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="$'bedingungen_gruppeA.csv' if expInfo['gruppe'] == 'odd' else 'bedingungen_gruppeB.csv'" valType="file"/>
