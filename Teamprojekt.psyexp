        <Param val="colorList = [&amp;#10;    &quot;red&quot;, &quot;green&quot;, &quot;blue&quot;, &quot;yellow&quot;,&amp;#10;    &quot;magenta&quot;, &quot;cyan&quot;, &quot;orange&quot;, &quot;purple&quot;&amp;#10;]&amp;#10;&amp;#10;causalColor = np.random.choice(colorList)&amp;#10;&amp;#10;ternusDuration = 0.2&amp;#10;&amp;#10;# default: invisible causal objects&amp;#10;portalOpacity = 0&amp;#10;barrierOpacity = 0&amp;#10;&amp;#10;# default Ternus color&amp;#10;ternusColor = &quot;black&quot;&amp;#10;&amp;#10;if condition == &quot;Portal&quot;:&amp;#10;    portalOpacity = 1&amp;#10;    barrierOpacity = 0&amp;#10;    ternusColor = causalColor&amp;#10;&amp;#10;elif condition == &quot;Barrier&quot;:&amp;#10;    portalOpacity = 0&amp;#10;    barrierOpacity = 1&amp;#10;    ternusColor = causalColor&amp;#10;&amp;#10;elif condition == &quot;Standard&quot;:&amp;#10;    portalOpacity = 0&amp;#10;    barrierOpacity = 0&amp;#10;    ternusColor = &quot;black&quot;&amp;#10;&amp;#10;thisExp.addData(&quot;causalColor&quot;, causalColor)" valType="extendedCode" updates="constant" name="Begin Routine"/>
